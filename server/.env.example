# Copy this file to server/.env and fill in real values.
# Note: if your MongoDB password contains reserved characters (@ : / ? # [ ] etc.),
# URL-encode them. Example: "Gaurav@1510" -> "Gaurav%401510".
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/stock_advisory_crm?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-string
PORT=4000
